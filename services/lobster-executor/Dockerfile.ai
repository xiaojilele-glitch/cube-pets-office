# AI-Enabled Sandbox Base Image
# Multi-runtime base with AI bridge — the AI agent inside the container
# decides what to install and execute based on the task.
#
# Build:
#   docker build -f Dockerfile.ai -t cube-ai-sandbox:latest .

FROM node:20-slim

# Install system essentials + Python 3
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    curl wget git jq ca-certificates \
    build-essential \
  && ln -sf /usr/bin/python3 /usr/bin/python \
  && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install AI SDK packages
RUN npm install -g \
    openai@4.73.0 \
    @langchain/core@0.3.26 \
    langchain@0.3.9 \
  && npm cache clean --force

# Copy AI Bridge module + autonomous executor
COPY ai-bridge/ /opt/ai-bridge/

# Create workspace and artifacts directories
RUN mkdir -p /workspace/artifacts

WORKDIR /workspace

# Default entrypoint: the AI executor script
# It reads the task from /workspace/task.json, calls LLM to plan,
# installs dependencies, executes code, and writes results.
ENTRYPOINT ["node", "/opt/ai-bridge/executor.js"]
