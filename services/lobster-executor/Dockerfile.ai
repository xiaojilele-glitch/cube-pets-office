# AI-Enabled Sandbox Base Image
# Pre-installs AI SDKs (openai, langchain) and the AI Bridge module
# so containers can call LLM APIs immediately after startup.
#
# Build:
#   docker build -f Dockerfile.ai -t cube-ai-sandbox:latest .

FROM node:20-slim

# Install AI SDK packages with pinned versions for reproducible builds
RUN npm install -g \
    openai@4.73.0 \
    @langchain/core@0.3.26 \
    langchain@0.3.9 \
  && npm cache clean --force

# Copy AI Bridge module into the image
COPY ai-bridge/ /opt/ai-bridge/

# Create workspace and artifacts directories
RUN mkdir -p /workspace/artifacts

WORKDIR /workspace
